# PostgreSQL Database Configuration (for Render, use the provided connection string)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/knowgapdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Server Configuration
PORT=8086

# JWT Configuration
JWT_SECRET=knowgapSecretKeyknowgapSecretKeyknowgapSecretKeyknowgapSecretKey

# Hugging Face API Configuration (get token from https://huggingface.co/settings/tokens)
HF_API_TOKEN=your_huggingface_token_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2
HF_API_URL=https://api-inference.huggingface.co/models

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8086

# Frontend API Configuration
# For local development: http://localhost:8086
# For production: https://knowgapbackend.onrender.com
REACT_APP_API_BASE_URL=https://knowgapbackend.onrender.com
